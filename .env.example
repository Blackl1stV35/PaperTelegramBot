###############################################################################
# .env.example — Copy to .env and fill in your values
#
# CLOUD TARGETS (pick any):
#   GCP Always Free  — e2-micro (2 vCPU, 1 GB, 30 GB disk)
#   AWS Free Tier    — t2.micro (1 vCPU, 1 GB, 30 GB EBS)
#   Azure Free       — B1s (1 vCPU, 1 GB)
#   Any VPS          — 1+ GB RAM
###############################################################################

# ── Service Ports ──
API_PORT=8000
REDIS_PORT=6379
RQ_DASHBOARD_PORT=9181

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ══════════════════════════════════════════════════════════════════
#  LLM PROVIDER — pick ONE, all are free tier
# ══════════════════════════════════════════════════════════════════
# Options: groq | together | cerebras | openrouter | ollama
# "ollama" still works if you self-host on a beefy machine elsewhere
LLM_PROVIDER=groq

# ── Groq (recommended — fastest, free 30 req/min) ──
# Sign up: https://console.groq.com (free, no credit card)
GROQ_API_KEY=gsk_your_key_here
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# ── Together AI (free $1 credit on signup ≈ 500+ calls) ──
# Sign up: https://api.together.xyz (free, no credit card)
TOGETHER_API_KEY=your_key_here
TOGETHER_TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct-Turbo
TOGETHER_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo

# ── Cerebras (free, fast inference) ──
# Sign up: https://cloud.cerebras.ai (free, no credit card)
CEREBRAS_API_KEY=your_key_here
CEREBRAS_TEXT_MODEL=llama-3.3-70b

# ── OpenRouter (free credits on signup) ──
# Sign up: https://openrouter.ai (free credits)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_TEXT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# ── Ollama (only if self-hosting elsewhere with enough RAM) ──
OLLAMA_HOST=http://your-ollama-server:11434
OLLAMA_TEXT_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=minicpm-v:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ══════════════════════════════════════════════════════════════════
#  RESEARCH CONFIGURATION
# ══════════════════════════════════════════════════════════════════

# ── Domains (comma-separated) ──
RESEARCH_DOMAINS=Agentic LLM Research,Auxiliary Scientific Research,Biology,Cosmology,Deep Learning,Quantum Research,Quantum Physics,Neuroscience,Deep Tech

# ── Ingestion Limits (keep low on 1 GB VMs) ──
MAX_PAPERS_PER_DAY=6
ARXIV_THROTTLE_SECONDS=5
PDF_DOWNLOAD_TIMEOUT=120

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Google Sheets (optional) ──
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=/app/data/google_credentials.json
GOOGLE_SHEETS_SPREADSHEET_NAME=Research Pipeline

# ── Notion (optional) ──
NOTION_ENABLED=false
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# ── Vector Store (uses lightweight SQLite-based store on low RAM) ──
CHROMA_PERSIST_DIR=/app/data/db/chroma
CHROMA_COLLECTION=research_papers
# On 1 GB VMs, embeddings use the LLM provider API instead of local model
EMBEDDING_PROVIDER=api

# ── Scheduling ──
DAILY_INGEST_HOUR=6
DAILY_INGEST_MINUTE=0
WEEKLY_SYNTHESIS_DAY=sunday
WEEKLY_SYNTHESIS_HOUR=18

# ── Logging ──
LOG_LEVEL=INFO
